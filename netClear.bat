@echo off
chcp 65001 >nul
echo ============================================================
echo                    网络修复与清理工具
echo ============================================================
echo.
echo  本工具将执行以下操作：
echo    [1] 刷新 DNS 缓存        - 清除过期的域名解析记录
echo    [2] 清空 ARP 缓存        - 重置局域网地址映射
echo    [3] 重置 Winsock 目录    - 修复网络连接问题
echo    [4] 重置 TCP/IP 协议栈   - 恢复网络默认配置
echo.
echo ============================================================
echo  正在执行，请稍候...
echo ============================================================
echo.

echo [1/4] 正在刷新 DNS 缓存...
ipconfig /flushdns
echo.

echo [2/4] 正在清空 ARP 缓存...
arp -d
echo.

echo [3/4] 正在重置 Winsock 目录...
netsh winsock reset
echo.

echo [4/4] 正在重置 TCP/IP 协议栈...
netsh int ip reset
echo.

echo ============================================================
echo                      操作已完成！
echo ============================================================
echo.
echo  提示：建议重启计算机以确保所有网络设置生效。
echo        部分操作需要管理员权限才能正常执行。
echo.
pause