@echo off
chcp 65001 >nul
echo ============================================================
echo                   Windows 资源管理器重启工具
echo ============================================================
echo.
echo  本工具用于重启 Windows 资源管理器 (explorer.exe)。
echo  适用场景：
echo    - 桌面或任务栏卡死、无响应
echo    - 文件资源管理器异常
echo    - 系统托盘图标显示异常
echo    - 桌面图标不刷新
echo.
echo ============================================================
echo  即将在 1 秒后执行重启...
echo ============================================================
echo.
timeout /t 1 /nobreak

echo [步骤 1/2] 正在终止 explorer.exe 进程...
taskkill /f /im explorer.exe
echo.

echo [步骤 2/2] 正在重新启动资源管理器...
explorer
echo.

echo ============================================================
echo                   资源管理器已重启完成！
echo ============================================================
echo.
echo  提示：如果桌面或任务栏仍未恢复正常，
echo        请尝试注销并重新登录，或重启计算机。
echo.
pause